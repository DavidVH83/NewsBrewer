# Copy to .env — never commit .env to GitHub

# Email Account 1 credentials
ACCOUNT_1_EMAIL=your@gmail.com
ACCOUNT_1_PASSWORD=your_app_password_here

# Email Account 2 credentials (optional)
ACCOUNT_2_EMAIL=your@outlook.com
ACCOUNT_2_PASSWORD=your_app_password_here

# SMTP credentials for sending digest
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your_smtp_app_password_here
DIGEST_RECIPIENT=you@yourdomain.com

# GitHub Models API token
# In GitHub Actions: automatically available as GITHUB_TOKEN
# For local testing: create a GitHub personal access token
GITHUB_TOKEN=ghp_your_token_here
